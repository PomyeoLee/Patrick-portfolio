# Databricks Lakeview dashboard embedding (server-minted token)
#
# Copy to .env.local and fill in values. Do NOT commit .env.local.

# Required (not a secret, but keep in env to avoid hardcoding)
DATABRICKS_WORKSPACE_URL="https://dbc-xxxxxxxx-xxxx.cloud.databricks.com"
DATABRICKS_WORKSPACE_ID="7474657136442266"

# Required (not a secret, but keep in env to avoid hardcoding)
# Your requested dashboard id:
DATABRICKS_DASHBOARD_ID="01f1360c3e9b1353b552230b71ad8da2"

# Required secrets (server-only)
# Service principal / OAuth client credentials used to mint scoped embed tokens.
DATABRICKS_CLIENT_ID="<<YOUR_CLIENT_ID>>"
DATABRICKS_CLIENT_SECRET="<<YOUR_CLIENT_SECRET>>"

# Optional (helps Databricks distinguish external viewers)
DATABRICKS_EXTERNAL_VIEWER_ID="portfolio-public-viewer"

# Optional (use if your tokeninfo endpoint requires it)
# DATABRICKS_EXTERNAL_VALUE=""
